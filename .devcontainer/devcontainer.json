{
  "name": "Resource Management Platform",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "features": {},
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Resource Manager (web app)",
      "onAutoForward": "openPreview"
    }
  },
  "postCreateCommand": "npm install && npm run db:reset",
  "postAttachCommand": {
    "web": "npm run dev"
  },
  "customizations": {
    "vscode": {
      "extensions": ["Prisma.prisma", "bradlc.vscode-tailwindcss"]
    }
  }
}
